# Wegent 配置示例
# 用法：复制本文件为 .env 后按需修改
#   cp .env.example .env
#
# 本文件同时被 docker-compose.yml 和 start.sh（本地开发）使用。
# 说明：docker-compose 仅在做变量插值（${VAR}）时读取本文件；
#       只有在 docker-compose.yml 中被引用的变量，才会真正传入容器。

# =============================================================================
# 通用配置（docker-compose 与 start.sh 共用）
# =============================================================================

# 前端连接后端使用的地址（浏览器侧地址，不是容器内网地址）
# - 本地开发：http://localhost:8000
# - 服务器部署：http://<服务器IP>:8000 或 http://your-domain.com:8000
WEGENT_SOCKET_URL=http://localhost:8000

# 前端端口（默认 3000）
WEGENT_FRONTEND_PORT=3000

# Executor 执行器镜像
EXECUTOR_IMAGE=ghcr.io/wecode-ai/wegent-executor:latest

# 镜像拉取策略：always | missing | never | if_not_present
# 默认 always（始终拉取最新镜像）；本地已有镜像可设为 never 避免联网拉取
# DOCKER_PULL_POLICY=always

# =============================================================================
# 服务间通信（主要用于 start.sh 本地开发）
# =============================================================================
# docker-compose 模式下，服务间地址会被容器名覆盖（如 http://backend:8000）

# 后端内部 API 鉴权的共享密钥（必填）
# start.sh 本地开发时若为空会自动生成；docker-compose 必须显式设置
# 生成方式：openssl rand -hex 32
INTERNAL_SERVICE_TOKEN=

# executor_manager 调用 backend 的地址
# 本地开发应使用宿主机 IP（不能用 localhost），以便容器可访问
# TASK_API_DOMAIN=http://YOUR_LOCAL_IP:8000

# backend / chat_shell 调用 executor_manager 的地址
# 本地开发通常为 http://localhost:8001
# EXECUTOR_MANAGER_URL=http://localhost:8001

# =============================================================================
# MySQL
# =============================================================================

# root 密码（生产环境务必修改！）
MYSQL_ROOT_PASSWORD=123456

# 数据库名
MYSQL_DATABASE=task_manager

# 业务库用户名 / 密码
MYSQL_USER=task_user
MYSQL_PASSWORD=task_password

# MySQL 端口（默认 3306）
# MYSQL_PORT=3306

# =============================================================================
# Redis
# =============================================================================

# Redis 端口（默认 6379）
# REDIS_PORT=6379

# executor_manager 客户端使用的 Redis 协议版本
# 默认 2（RESP2），兼容不支持 HELLO 命令的老版本/兼容实现
# 仅当 Redis 服务端支持 RESP3 时才设为 3
# REDIS_PROTOCOL=2

# =============================================================================
# MinIO（S3 兼容对象存储，随 docker-compose 启动）
# =============================================================================
# 附件 / 技能 / 插件 / 工作区文件的二进制全部存放于对象存储（仅支持 S3）。
# minio-init 会在首次启动时创建所需 Bucket：
#   attachments、skills、wegent-archives、wegent-workspace-files
#
# 控制台：http://localhost:9001（默认账号见下）
# API：    http://localhost:9000

# MinIO 根账号（未单独配置 S3 access key/secret 时也作为其默认值）
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# 宿主机发布端口
# MINIO_API_PORT=9000
# MINIO_CONSOLE_PORT=9001

# =============================================================================
# 附件 / 技能 / 工作区文件存储（docker-compose → backend）
# =============================================================================
# 存储为「仅对象存储」：二进制存 MinIO，MySQL 只保留元数据 + storage_key。
# 旧的 "mysql" 后端已移除，可选值仅 s3 | minio（两者使用同一套 S3 客户端）。
#
# 关键网络区分：
# - ATTACHMENT_S3_ENDPOINT       内网端点，服务端访问用（backend、executor 上传 workspace 文件的 PUT）
# - ATTACHMENT_S3_PUBLIC_ENDPOINT 公网端点，浏览器/加解密网关访问用（预签名下载）
#
# init_data 内置技能（backend/init_data/skills/）在首次 YAML 初始化时上传到 MinIO。

# 存储后端：s3 | minio
ATTACHMENT_STORAGE_BACKEND=s3

# 内网端点（容器内通过服务名访问 MinIO）
# ATTACHMENT_S3_ENDPOINT=http://minio:9000

# 公网端点（预签名 URL 用，需为浏览器可达的 host:port）
# 接入企业文件加解密网关时，指向网关地址：
# ATTACHMENT_S3_PUBLIC_ENDPOINT=http://localhost:9000

# S3 凭据（默认取 MINIO_ROOT_USER / MINIO_ROOT_PASSWORD）
# ATTACHMENT_S3_ACCESS_KEY=minioadmin
# ATTACHMENT_S3_SECRET_KEY=minioadmin

# Bucket 名称（由 minio-init 自动创建，自定义时需与 minio-init 保持一致）
# ATTACHMENT_S3_BUCKET=attachments
# ATTACHMENT_S3_SKILL_BUCKET=skills
# WORKSPACE_ARCHIVE_BUCKET=wegent-archives
# WORKSPACE_FILES_BUCKET=wegent-workspace-files

# ATTACHMENT_S3_REGION=us-east-1
# ATTACHMENT_S3_USE_SSL=False

# =============================================================================
# 工作区归档 / 工作区文件同步
# =============================================================================
# - 归档：将整个工作区打包存到对象存储，用于空闲回收后再恢复。
# - 文件同步：子任务完成时增量地把工作区文件同步到 S3，
#   使「查看任务文件」可直接走 S3 列表/下载。

# 工作区归档开关
# WORKSPACE_ARCHIVE_ENABLED=true

# 工作区文件增量同步开关
# WORKSPACE_SYNC_ENABLED=true

# 单文件同步大小上限（MB），超过则跳过
# WORKSPACE_SYNC_MAX_FILE_SIZE_MB=100

# 预签名 URL 有效期（秒）
# WORKSPACE_SYNC_PRESIGN_EXPIRE_SECONDS=3600

# =============================================================================
# Elasticsearch（RAG 功能）
# =============================================================================

# Elasticsearch 端口（默认 9200）
# ES_PORT=9200

# Elasticsearch JVM 内存参数
# ES_JAVA_OPTS=-Xms1g -Xmx1g

# =============================================================================
# 分享配置
# =============================================================================
# 生成智能体 / 任务分享链接时使用的基础 URL（生产部署务必修改！）
# - 本地开发：http://localhost:3000
# - 服务器部署：http://your-domain.com 或 https://your-domain.com

# 智能体分享基础 URL（含 /chat 路径）
TEAM_SHARE_BASE_URL=http://localhost:3000/chat
# 任务分享基础 URL
TASK_SHARE_BASE_URL=http://localhost:3000
# 智能体分享 token 的查询参数名
TEAM_SHARE_QUERY_PARAM=teamShare

# =============================================================================
# Backend 后端
# =============================================================================

# 后端端口（默认 8000）
BACKEND_PORT=8000

# uvicorn worker 进程数（docker-compose 会覆盖镜像默认值）
# BACKEND_UVICORN_WORKERS=8

# 运行环境
# BACKEND_ENVIRONMENT=development

# JWT 签名密钥（生产环境务必修改！）
# BACKEND_SECRET_KEY=your-secret-key-here

# JWT 算法
# BACKEND_ALGORITHM=HS256

# 访问令牌有效期（分钟，默认 10080 = 7 天）
# BACKEND_ACCESS_TOKEN_EXPIRE_MINUTES=10080

# 任务追加超时（小时）
# BACKEND_APPEND_CHAT_TASK_EXPIRE_HOURS=2
# BACKEND_APPEND_CODE_TASK_EXPIRE_HOURS=2

# Executor 容器自动删除阈值（分钟，支持小于 1 小时的值以更快释放容器）
# 这是 backend 的定时清理，按任务状态 + updated_at 判断
# BACKEND_CHAT_TASK_EXECUTOR_DELETE_AFTER_MINUTES=120
# BACKEND_CODE_TASK_EXECUTOR_DELETE_AFTER_MINUTES=1440
# 长期处于非终态（卡住）任务的容器删除阈值（分钟）
# BACKEND_STALE_NON_TERMINAL_TASK_EXECUTOR_DELETE_AFTER_MINUTES=1440

# 文件上传限制
# BACKEND_MAX_UPLOAD_FILE_SIZE_MB=50
# BACKEND_MAX_SKILL_SIZE=10
# BACKEND_MAX_EXTRACTED_TEXT_LENGTH=1000000

# 知识库分块内容是否落库（默认 false，仅存向量库用于检索；
# 开启后分块内容也会写入 knowledge_documents.chunks 供前端查看）
# BACKEND_CHUNK_STORAGE_ENABLED=False

# 启动时初始化内置数据
# BACKEND_INIT_DATA_ENABLED=True

# =============================================================================
# Chat Shell
# =============================================================================

# Chat Shell 端口（默认 8100）
CHAT_SHELL_PORT=8100

# uvicorn worker 进程数（docker-compose 会覆盖镜像默认值）
# CHAT_SHELL_UVICORN_WORKERS=8

# =============================================================================
# Executor Manager 执行器管理
# =============================================================================

# Executor Manager 端口（默认 8001）
EXECUTOR_MANAGER_PORT=8001

# 最大并发任务数
# EXECUTOR_MAX_CONCURRENT_TASKS=30

# Executor 端口范围
# EXECUTOR_PORT_RANGE_MIN=10001
# EXECUTOR_PORT_RANGE_MAX=10100

# Executor 工作区目录
# EXECUTOR_WORKSPACE=${HOME}/wecode-bot

# 空闲容器 GC（Docker 模式）：回收当前没有运行任何任务的普通任务容器。
# 这是一套「不依赖数据库」的兜底机制，也会清理 `docker compose down` 后残留的孤儿容器。
# EXECUTOR_IDLE_TIMEOUT_MINUTES=30        # 容器空闲超过该时长（分钟）即回收
# EXECUTOR_IDLE_GC_INTERVAL_SECONDS=120   # GC 扫描间隔（秒）
# Sandbox 空闲 TTL（分钟）：空闲超过该时长的 sandbox 会被回收
# SANDBOX_IDLE_TIMEOUT_MINUTES=1440

# 时区
# TZ=Asia/Shanghai

# Docker 宿主机地址（默认 host.docker.internal，host 模式下连接 executor 容器用）
# DOCKER_HOST_ADDR=host.docker.internal

# =============================================================================
# Knowledge Runtime 知识运行时
# =============================================================================

# Knowledge Runtime 端口（默认 8200）
KNOWLEDGE_RUNTIME_PORT=8200

# RAG 运行模式（remote 模式很重要）
# - "local"（默认）：RAG 操作在 Backend 本地执行
# - "remote"：转发给 knowledge_runtime 服务执行
# RAG_RUNTIME_MODE={"default":"remote"}

# Knowledge Runtime 回调 Backend 取内容的内部地址
# docker-compose 默认 http://backend:8000；本地开发默认 http://localhost:8000
# BACKEND_INTERNAL_URL=http://backend:8000

# Backend 调用 Knowledge Runtime 的地址
# docker-compose 默认 http://knowledge_runtime:8200；本地开发默认 http://localhost:8200
# KNOWLEDGE_RUNTIME_URL=http://knowledge_runtime:8200

# 内容抓取超时（秒，默认 120）
# CONTENT_FETCH_TIMEOUT=120

# 日志配置（默认开启文件日志）
# LOG_FILE_ENABLED=true
# LOG_DIR=/app/logs
# LOG_LEVEL=INFO

# =============================================================================
# 知识库文档转换（Knowledge Doc Converter）
# =============================================================================
# 将 PDF/PPTX 通过 OCR 转为 Markdown 的 Celery worker。

# 是否启用文档转换分发（backend 侧）
# KNOWLEDGE_CONVERSION_ENABLED=false
# 触发转换的文件类型
# KNOWLEDGE_CONVERSION_FILE_TYPES=pdf

# OCR 提供方：mineru | paddleocr
# CONVERSION_PROVIDER=mineru

# PaddleOCR 配置（CONVERSION_PROVIDER=paddleocr 时使用）
# PADDLEOCR_TOKEN=your-paddleocr-token
# PADDLEOCR_MODEL=PaddleOCR-VL-1.6

# MinerU 配置（CONVERSION_PROVIDER=mineru 时使用）
# MINERU_API_BASE_URL=
# MINERU_PARSE_METHOD=ocr
# MINERU_LANG_LIST=ch

# =============================================================================
# Web 搜索（传给 backend + chat_shell）
# =============================================================================

# WEB_SEARCH_ENABLED=true
# TAVILY_API_KEY=tvly-your-api-key
# WEB_SEARCH_ENGINES={"default":"tavily","engines":{"tavily":{"type":"tavily","display_name":"Tavily"}}}
# TAVILY_AUTO_PARAMETERS=true
# TAVILY_INCLUDE_FAVICON=true
# TAVILY_SAFE_SEARCH=false
# TAVILY_INCLUDE_USAGE=true
# TAVILY_COUNTRY=CN
# WEB_SEARCH_DEFAULT_MAX_RESULTS=10

# =============================================================================
# MCP（Model Context Protocol）
# =============================================================================
# MCP 服务器配置支持 ${{path}} 变量替换（如 "headers": {"X-User": "${{user.name}}"}）
# 可用变量：user.name、user.id
# 完整格式见 backend/app/core/config.py 中的 CHAT_MCP_SERVERS
